@push('scripts')
<script>
$(document).ready(function() {
    let table;
    let selectedYear = {{ $year }};
    let selectedMonth = {{ $month }};
    let selectedStatus = '';
    let selectedType = '';

    function loadTable() {
        if (table) {
            table.destroy();
        }

        table = $('#paymentsTable').DataTable({
            processing: true,
            serverSide: true,
            ajax: {
                url: '{{ route('subscriptions.payments') }}',
                data: {
                    year: selectedYear,
                    month: selectedMonth,
                    subscription_type_id: selectedType,
                    status: selectedStatus
                }
            },
            columns: [
                { data: 'apartment_number', name: 'apartment_number' },
                { data: 'resident_name', name: 'resident_name' },
                { data: 'subscription_type_name', name: 'subscription_type_name' },
                { data: 'amount', name: 'amount' },
                { data: 'status_label', name: 'status' },
                { data: 'action', name: 'action', orderable: false, searchable: false }
            ],
            language: {
                url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/ar.json'
            },
            drawCallback: function() {
                updateStatistics();
            }
        });
    }

    function updateStatistics() {
        $.get('{{ route('subscriptions.payments') }}', {
            year: selectedYear,
            month: selectedMonth,
            subscription_type_id: selectedType,
            status: selectedStatus
        }, function(response) {
            const data = response.data || [];
            const paidCount = data.filter(s => s.status === 'paid').length;
            const pendingCount = data.filter(s => s.status === 'pending').length;
            const overdueCount = data.filter(s => s.status === 'overdue').length;

            $('#paidCount').text(paidCount);
            $('#pendingCount').text(pendingCount);
            $('#overdueCount').text(overdueCount);
        });
    }

    // Year filter
    $('.year-btn').click(function() {
        $('.year-btn').removeClass('active');
        $(this).addClass('active');
        selectedYear = $(this).data('year');
        loadTable();
    });

    // Month filter
    $('.month-btn').click(function() {
        $('.month-btn').removeClass('active');
        $(this).addClass('active');
        selectedMonth = $(this).data('month');
        loadTable();
    });

    // Status filter
    $('.status-btn').click(function() {
        $('.status-btn').removeClass('active');
        $(this).addClass('active');
        selectedStatus = $(this).data('status');
        loadTable();
    });

    // Type filter
    $('.type-btn').click(function() {
        $('.type-btn').removeClass('active');
        $(this).addClass('active');
        selectedType = $(this).data('type');
        loadTable();
    });

    // Initial load
    loadTable();

    // Add payment button
    $('#addPaymentBtn').click(function() {
        $('#addPaymentModalContent').html('<div class="text-center p-5"><i class="fas fa-spinner fa-spin fa-3x text-primary"></i><p class="mt-3">جاري التحميل...</p></div>');
        $('#addPaymentModal').modal('show');

        // Load the create form via AJAX
        $.get('{{ route('subscriptions.create') }}', function(response) {
            $('#addPaymentModalContent').html(response.html);
        }).fail(function() {
            $('#addPaymentModalContent').html(`
                <div class="alert alert-danger m-3">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    حدث خطأ أثناء تحميل النموذج. يرجى المحاولة مرة أخرى.
                </div>
            `);
        });
    });

    // Mark as paid
    $(document).on('click', '.mark-paid-btn', function() {
        const id = $(this).data('id');
        if (confirm('هل تريد تسجيل هذا الاشتراك كمدفوع؟')) {
            $.ajax({
                url: `/subscriptions/${id}/mark-paid`,
                method: 'POST',
                success: function(response) {
                    toastr.success(response.message);
                    table.ajax.reload();
                },
                error: function() {
                    toastr.error('حدث خطأ أثناء تسجيل الدفع');
                }
            });
        }
    });

    // Send reminders
    $('#sendRemindersBtn').click(function() {
        if (confirm('هل تريد إرسال تذكير لجميع المتأخرين عن الدفع؟')) {
            $.ajax({
                url: '{{ route('subscriptions.send-late-reminders') }}',
                method: 'POST',
                data: {
                    year: selectedYear,
                    month: selectedMonth,
                    subscription_type_id: selectedType
                },
                success: function(response) {
                    toastr.success(response.message);
                },
                error: function() {
                    toastr.error('حدث خطأ أثناء إرسال التذكيرات');
                }
            });
        }
    });
});
</script>
@endpush
